#!/bin/sh

BINDIR=`dirname "$0"`
USERVER_PYTHON="${USERVER_PYTHON:-python3}"
CHAOTIC_INSTALL_DIR="$BINDIR/../@CMAKE_INSTALL_LIBDIR@/userver"

CHAOTIC_DIR="$BINDIR/..:$BINDIR/../../chaotic"
CHAOTIC_MAIN="$BINDIR/../chaotic_openapi/main.py"
if ! [ -e "$CHAOTIC_MAIN" ]; then
    CHAOTIC_DIR="$CHAOTIC_INSTALL_DIR"
    CHAOTIC_MAIN="$CHAOTIC_DIR/chaotic_openapi/main.py"
fi

export PYTHONPATH="$CHAOTIC_DIR"
exec "$USERVER_PYTHON" "$CHAOTIC_MAIN" "$@"
