{% import 'templates/stream_writer.jinja' as sw %}
#include "{{ pair_header }}.hpp"

#include <userver/chaotic/type_bundle_cpp.hpp>

#include "{{ pair_header }}_parsers.ipp"

{% if generate_sax_parser %}
#include "{{ pair_header }}_sax_parsers.hpp"
{% endif %}

{% macro generate_parser_definition_call(type, format) %}
    {% if not type.may_generate_for_format(format) %}
        /* Parse({{ format }}::Value, To<{{ shortest_cpp_name(type) }}>) was not generated: {{ type.only_json_reason() }} */
    {% else %}
        {{ _generate_parser_definition_call(type, format) }}
    {% endif %}
{% endmacro %}


{% macro _generate_parser_definition_call(type, format) %}
    {# handle subtypes #}
    {%- for schema in type.subtypes() -%}
        {{ generate_parser_definition_call(schema, format) }}
    {% endfor %}

    {% if type.need_dom_parser() %}
        {{ type.raw_cpp_type.in_scope(get_current_namespace()) }} Parse({{ format }}::Value json,
                                                 {{ userver }}::formats::parse::To<{{ shortest_cpp_name(type) }}> to)
    {
        return Parse<{{ format }}::Value>(json, to);
    }
    {% endif %}
{% endmacro %}


{% macro generate_from_json_string_definition(type) %}
    {% if type.get_py_type() == 'CppStruct' %}
        {{ shortest_cpp_name(type) }} FromJsonString(std::string_view json,
            {{ userver }}::formats::parse::To<{{ shortest_cpp_name(type) }}>)
        {
          {% if generate_sax_parser %}
              return {{ userver }}::formats::json::parser::ParseToType<
                   {{ shortest_cpp_name(type) }},
                   {{ userver }}::chaotic::sax::impl::RemoveUserTypeParser<
                       {{ userver }}::chaotic::sax::Parser<{{ shortest_cpp_name(type) }}>
                   >
              >(json);
          {% else %}
              return {{ userver }}::formats::json::FromString(json).As<{{ shortest_cpp_name(type) }}>();
          {% endif %}
        }
    {% endif %}
{% endmacro %}


{% macro generate_to_json_string_definition(type) %}
    {% if type.get_py_type() == 'CppStruct' %}
        std::string ToJsonString(const {{ shortest_cpp_name(type) }}& value) {
          {% if generate_stream_writer %}
              {{ userver }}::formats::json::StringBuilder builder;
              WriteToStream(value, builder);
              return builder.GetString();
          {% else %}
              return ToString({{ userver }}::formats::json::ValueBuilder(value).ExtractValue());
          {% endif %}
        }
    {% endif %}
{% endmacro %}


{% macro generate_string_parser_definition(type) %}
    {# handle subtypes #}
    {%- for schema in type.subtypes() -%}
        {{ generate_string_parser_definition(schema) }}
    {% endfor %}

    {% if type.need_dom_parser() %}
        {% set local_name = shortest_cpp_name(type) %}
        {% if type.get_py_type() == 'CppIntEnum' %}
            {{ local_name }} Convert(std::int64_t value, {{ userver }}::chaotic::convert::To<{{ local_name }}>) {
                const auto result = k{{ type.cpp_global_struct_field_name() }}_Mapping.TryFindBySecond(value);
                if (result.has_value()) {
                    return *result;
                }
                throw std::runtime_error(fmt::format("Invalid enum value ({}) for type {{ type.cpp_global_name() }}", value));
            }

            std::optional<{{ local_name }}> TryConvert(std::int64_t value, {{ userver }}::chaotic::convert::To<{{ local_name }}>) noexcept {
                return k{{ type.cpp_global_struct_field_name() }}_Mapping.TryFindBySecond(value);
            }
        {% elif type.get_py_type() == 'CppStringEnum' %}
            {{ local_name }} Convert(std::string_view value,
                            {{userver}}::chaotic::convert::To<{{ local_name }}>)
            {
                const auto result = k{{ type.cpp_global_struct_field_name() }}_Mapping.TryFindBySecond(value);
                if (result.has_value()) {
                    return *result;
                }
                throw std::runtime_error(fmt::format("Invalid enum value ({}) for type {{ type.cpp_global_name() }}", value));
            }

            std::optional<{{ local_name }}> TryConvert(std::string_view value, {{userver}}::chaotic::convert::To<{{ local_name }}>) noexcept
            {
                return k{{ type.cpp_global_struct_field_name() }}_Mapping.TryFindBySecond(value);
            }

            {{ local_name }} Parse(std::string_view value, {{userver}}::formats::parse::To<{{ local_name }}>)
            {
                return Convert(value, {{userver}}::chaotic::convert::To<{{ local_name }}>{});
            }
        {% endif %}
    {% endif %}
{% endmacro %}


{% macro generate_serializer_definition(type) %}
    {% set local_name = shortest_cpp_name(type) %}

    {# handle subtypes #}
    {%- for schema in type.subtypes() -%}
        {{ generate_serializer_definition(schema) }}
    {% endfor %}

    {% if type.get_py_type() == 'CppStruct' %}
        {{ userver }}::formats::json::Value Serialize(
            [[maybe_unused]] const {{ local_name }}& value,
            {{ userver }}::formats::serialize::To<{{ userver }}::formats::json::Value>
        )
        {
            {{ userver }}::formats::json::ValueBuilder vb
                {%- if type.extra_type == True -%}
                    {# additionalProperties: true #}
                    = value.extra;
                {%- elif type.extra_type -%}
                    {# additionalProperties: ... #}
                    ;

                    for (const auto&[field_key, field_value]: value.extra) {
                        vb.EmplaceNocheck(field_key,
                            {{ type.extra_type.parser_type('', '') }}{
                                field_value
                            }
                        );
                    }
                {%- else -%}
                    {# additionalProperties: false #}
                    = {{ userver }}::formats::common::Type::kObject;
                {%- endif %}

            {# properties #}
            {%- for fname, field in type.fields.items() -%}
                {% if field.is_optional() %}
                    if (value.{{ field.cpp_field_name() }}) {
                        vb["{{ fname }}"] =
                            {{ field.schema.parser_type('', '') }}{
                                *value.{{ field.cpp_field_name() }}
                            };
                    }
                {% else %}
                    vb["{{ fname }}"] =
                        {{ field.schema.parser_type('', '') }}{
                            value.{{ field.cpp_field_name() }}
                        };
                {% endif %}
            {%- endfor %}

            {# additionalProperties #}
            return vb.ExtractValue();
        }
    {% elif not type.needs_new_type() %}
        {# No new type #}
    {% elif type.get_py_type() == 'CppIntEnum' %}
        {{ userver }}::formats::json::Value Serialize(
            const {{ local_name }}& value,
            {{ userver }}::formats::serialize::To<{{ userver }}::formats::json::Value> to
        )
        {
            const auto result = k{{ type.cpp_global_struct_field_name() }}_Mapping.TryFindByFirst(value);
            if (result.has_value()) {
                return Serialize(*result, to);
            }
            {#- TODO: text #}
            throw std::runtime_error("Bad enum value");
        }
    {% elif type.get_py_type() == 'CppStringEnum' %}
        {{ userver }}::formats::json::Value Serialize(
            const {{ local_name }}& value,
            {{ userver }}::formats::serialize::To<{{ userver }}::formats::json::Value>
        )
        {
            return {{ userver }}::formats::json::ValueBuilder(ToString(value)).ExtractValue();
        }
    {% elif type.get_py_type() == 'CppStructAllOf' %}
        {# parse allOf #}
        {{ userver }}::formats::json::Value Serialize(
            const {{ local_name }}& value,
            {{ userver }}::formats::serialize::To<{{ userver }}::formats::json::Value>
        )
        {
            {{ userver }}::formats::json::ValueBuilder vb =
                {{ userver }}::formats::common::Type::kObject;

            {%- for parent in type.parents -%}
                {{userver}}::formats::common::Merge(
                    vb,
                    {{ userver }}::formats::json::ValueBuilder{static_cast<{{ shortest_cpp_name(parent) }}>(value)}.ExtractValue()
                );
            {%- endfor -%}

            return vb.ExtractValue();
        }
    {% else %}
        {{ NOT_IMPLEMENTED(type) }}
    {% endif %}
{% endmacro %}

{% macro generate_tostring_definition(type) %}
    {# handle subtypes #}
    {%- for schema in type.subtypes() -%}
        {{ generate_tostring_definition(schema) }}
    {% endfor %}

    {% if type.get_py_type() in ('CppIntEnum', 'CppStringEnum') %}
        std::string ToString({{ shortest_cpp_name(type) }} value) {
            const auto result = k{{ type.cpp_global_struct_field_name() }}_Mapping.TryFindByFirst(value);
            if (result.has_value()) {
                {% if type.get_py_type() == 'CppIntEnum' %}
                    return std::to_string(static_cast<int>(*result));
                {% elif type.get_py_type() == 'CppStringEnum' %}
                    return std::string{*result};
                {% endif %}
            }
            throw std::runtime_error(fmt::format("Invalid enum value: {}", static_cast<int>(value)));
        }
    {% endif %}
{% endmacro %}


{% macro generate_operator_eq_definition(type) %}
    {% set local_name = shortest_cpp_name(type) %}

    {# handle subtypes #}
    {%- for schema in type.subtypes() -%}
        {{ generate_operator_eq_definition(schema) }}
    {% endfor %}

    {% if type.get_py_type() == 'CppStruct' %}
        bool operator==(const {{ local_name }} & lhs,const {{ local_name }} & rhs) {
          {%- if not type.fields %} 
            (void)lhs;
            (void)rhs;
          {% endif %}
            return
            {% for fname, field in type.fields.items() -%}
                lhs.{{ field.cpp_field_name() }} == rhs.{{ field.cpp_field_name() }}
                &&
            {%- endfor -%}
            {% if type.extra_type %}
                lhs.extra == rhs.extra
                &&
            {% endif %}
                true;
        }
    {% elif type.get_py_type() == 'CppStructAllOf' %}
        bool operator==(const {{ local_name }} & lhs,const {{ local_name }} & rhs) {
            return
            {% for parent in type.parents -%}
                    static_cast<const {{ shortest_cpp_name(parent) }}&>(lhs) ==
                    static_cast<const {{ shortest_cpp_name(parent) }}&>(rhs)
                {% if not loop.last %} && {% endif -%}
            {%- endfor -%}
                ;
        }
    {% elif not type.needs_new_type() or type.get_py_type() in ('CppIntEnum', 'CppStringEnum') %}
        {# No new type #}
    {% else %}
        {{ NOT_IMPLEMENTED(type) }}
    {% endif %}
{% endmacro %}

{% macro generate_operator_lshift_definition(type) %}
    {# handle subtypes #}
    {%- for schema in type.subtypes() -%}
        {{ generate_operator_lshift_definition(schema) }}
    {% endfor %}

    {% if type.get_py_type() == 'CppStringEnum' %}
        {{ userver }}::logging::LogHelper& operator<<({{ userver }}::logging::LogHelper& lh, const {{ shortest_cpp_name(type) }}& value)
        {
            return lh << ToString(value);
        }
    {% elif type.need_operator_lshift() %}
        {% if generate_serializer %}
            {{ userver }}::logging::LogHelper& operator<<({{ userver }}::logging::LogHelper& lh, const {{ shortest_cpp_name(type) }}& value)
            {
                return lh << ToString({{ userver }}::formats::json::ValueBuilder(value).ExtractValue());
            }
        {% endif %}
    {% endif %}
{% endmacro %}


{% macro generate_fmt_formatter_definition(type) %}
    {# handle subtypes #}
    {%- for schema in type.subtypes() -%}
        {{ generate_fmt_formatter_definition(schema) }}
    {% endfor %}
    
    {% if type.get_py_type() in ('CppIntEnum', 'CppStringEnum') %}
        fmt::format_context::iterator fmt::formatter<{{ shortest_cpp_name(type) }}>::format(const {{ shortest_cpp_name(type) }}& value, fmt::format_context& ctx) const {
            return fmt::format_to(ctx.out(), "{}", ToString(value));
        }
    {% endif %}
{% endmacro %}

{% import 'templates/common.jinja' as common %}

{% for name, type in types.items() %}
    {{ common.switch_namespace(cpp_namespace(name)) }}

    {% if has_json_parse(parse_formats) %}
        {{ generate_from_json_string_definition(type) }}
        {% if generate_serializer %}
            {{ generate_to_json_string_definition(type)  }}
        {% endif %}
    {% endif %}

    {{ generate_operator_eq_definition(type) }}

    {{ generate_operator_lshift_definition(type) }}

    {% for parse_format in parse_formats %}
        {{ generate_parser_definition_call(type, userver + parse_format) }}
    {% endfor %}

    {{ generate_string_parser_definition(type) }}

    {% if generate_serializer %}
        {{ generate_serializer_definition(type) }}
        {% if generate_stream_writer %}
            {{ sw.generate_stream_writer_definition(userver, type) }}
        {% endif %}
    {% endif %}

    {{ generate_tostring_definition(type) }}
{% endfor %}

{{ common.switch_namespace('') }}

{% for type in types.values() %}
    {{generate_fmt_formatter_definition(type)}}
{% endfor %}
