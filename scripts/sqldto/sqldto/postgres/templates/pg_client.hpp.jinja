{%- from "helpers.inc" import codegen_alert, simple_cpp_type, row_type, query_return_type, is_struct -%}
{{ codegen_alert() }}

#pragma once

{% for include in includes %}
    #include {{ include }}
{%- endfor %}

#include <{{ namespace }}/pg_models.hpp>

namespace {{ namespace }} {

{% for query in queries if is_struct(query) %}
    struct {{ query.returns.cpp_name }} {
        {%- for field in query.returns.fields %}
            {%- set type = simple_cpp_type(field.cpp_type) -%}
            {%- set init = '{}' if field.cpp_type.explicit_default else '' -%}
            {{ type }} {{ field.cpp_name }}{{ init }};
        {%- endfor %}
    };
{% endfor %}

class PgClient {
public:
    using HostType = USERVER_NAMESPACE::storages::postgres::ClusterHostTypeFlags;

    {%- for query in queries %}

        virtual {{ query_return_type(query) }} {{ query.cpp_name }}(
            HostType host_type
            {%- for arg in query.args %}
                ,const {{ simple_cpp_type(arg.cpp_type) }}& arg{{ loop.index }}
            {%- endfor %}
            ) const = 0;

    {%- endfor %}

    virtual ~PgClient() = default;
};


} // namespace {{ namespace }}
