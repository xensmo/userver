{%- macro codegen_alert() -%}
    /* THIS FILE IS AUTOGENERATED, DON'T EDIT! */
{%- endmacro -%}


{%- macro finite_cpp_type(type) -%}
    {{- type.typename -}}
    {%- if type.templates -%}
        <
        {%- for template in type.templates -%}
            {{- template.value -}}
            {%- if not loop.last -%},{%- endif -%}
        {%- endfor -%}
        >
    {%- endif -%}
{%- endmacro -%}


{%- macro wrapper_cpp_type(type, wrappers=[]) -%}
    {%- if wrappers -%}
        {{- wrappers[0] -}}<{{- wrapper_cpp_type(type, wrappers[1:]) -}}>
    {%- else -%}
        {{- finite_cpp_type(type) -}}
    {%- endif -%}
{%- endmacro -%}


{%- macro simple_cpp_type(type) -%}
    {{- wrapper_cpp_type(type, type.wrappers) -}}
{%- endmacro -%}


{%- macro is_void(query) -%}
    {%- if not query.returns.fields -%}1{%- endif -%}
{%- endmacro -%}


{%- macro is_struct(query) -%}
    {%- if query.returns.fields | length > 1 -%}1{%- endif -%}
{%- endmacro -%}


{%- macro row_type(query) -%}
    {%- if is_struct(query) -%}
        {{- query.returns.cpp_name -}}
    {%- else -%}
        {{- simple_cpp_type(query.returns.fields[0].cpp_type) -}}
    {%- endif -%}
{%- endmacro -%}


{%- macro query_return_type(query) -%}
    {%- if is_void(query) -%}
        void
    {%- elif query.cardinality == "one" -%}
        {{- row_type(query) -}}
    {%- elif query.cardinality == "optional" -%}
        std::optional<{{- row_type(query) -}}>
    {%- else -%}
        std::vector<{{- row_type(query) -}}>
    {%- endif -%}
{%- endmacro -%}
